@@ -82,6 +206,11 @@ static void *sdl_input_init(const char *joypad_driver)
 
    input_keymaps_init_keyboard_lut(rarch_key_map_sdl);
 
+#ifdef HAVE_MALI_FBDEV
+   sdl_evdev_build_lut();
+   sdl_evdev_open_keyboards();
+#endif
+
    return sdl;
 }
 
@@ -119,10 +248,22 @@ static bool sdl_key_pressed(int key)
       return true;
 #endif
 
-   if (sym >= (unsigned)num_keys)
-      return false;
+   if (sym < (unsigned)num_keys && keymap[sym])
+      return true;
 
-   return keymap[sym];
+#ifdef HAVE_MALI_FBDEV
+   /* Also check direct evdev keyboard state — SDL2 keyboard input
+    * doesn't work on mali_fbdev since SDL_INIT_VIDEO is never called. */
+   {
+      unsigned linux_code = (key < RETROK_LAST)
+         ? sdl_evdev_rk_to_linux[key] : 0;
+      if (linux_code && linux_code < KEY_CNT
+            && sdl_evdev_key_state[linux_code])
+         return true;
+   }
+#endif
+
+   return false;
 }
 
 static int16_t sdl_input_state(
@@ -352,6 +493,10 @@ static void sdl_input_free(void *data)
    linux_close_illuminance_sensor(sdl->illuminance_sensor); /* noop if NULL */
 #endif
 
+#ifdef HAVE_MALI_FBDEV
+   sdl_evdev_close_keyboards();
+#endif
+
    free(data);
 }
 
@@ -456,6 +601,10 @@ static void sdl_input_poll(void *data)
 
    sdl_poll_mouse(sdl);
 
+#ifdef HAVE_MALI_FBDEV
+   sdl_evdev_poll_keyboards();
+#endif
+
 #ifdef HAVE_SDL2
    while (SDL_PeepEvents(&event, 1,
             SDL_GETEVENT, SDL_KEYDOWN, SDL_MOUSEWHEEL) > 0)
