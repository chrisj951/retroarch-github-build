+ * framebuffer (e.g. Miyoo A30 480x640 panel used in landscape). */
+static INLINE void gl2_viewport_rot(GLint x, GLint y, GLsizei w, GLsizei h)
+{
+   if (config_get_ptr()->uints.video_rotation % 2 != 0)
+      glViewport(y, x, h, w);
+   else
+      glViewport(x, y, w, h);
+}
