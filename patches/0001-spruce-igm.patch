diff --git a/spruce_igm.c b/spruce_igm.c
new file mode 100644
index 0000000..97c1e0e
--- /dev/null
+++ b/spruce_igm.c
@@ -0,0 +1,388 @@
+/*
+ * Spruce IGM - Simple in-game menu for spruceOS handhelds
+ *
+ * Renders a minimal quick menu over the paused game frame.
+ * Controlled with d-pad and face buttons (no touchscreen needed).
+ *
+ * Menu items:
+ *   Resume / Save State / Load State / Reset / Exit / RetroArch Menu
+ */
+
+#include "spruce_igm.h"
+
+#include <string.h>
+#include <stdio.h>
+
+#include "retroarch.h"
+#include "configuration.h"
+#include "command.h"
+#include "runloop.h"
+#include "gfx/gfx_display.h"
+#include "gfx/font_driver.h"
+#include "input/input_driver.h"
+
+/* ── Menu item definitions ─────────────────────────────────── */
+
+enum spruce_igm_item
+{
+   IGM_RESUME = 0,
+   IGM_SAVE_STATE,
+   IGM_LOAD_STATE,
+   IGM_RESET,
+   IGM_EXIT,
+   IGM_RETROARCH,
+   IGM_ITEM_COUNT
+};
+
+static const char *igm_labels[IGM_ITEM_COUNT] = {
+   "Resume",
+   "Save State",
+   "Load State",
+   "Reset",
+   "Exit Game",
+   "RetroArch Menu"
+};
+
+/* ── Gruvbox-inspired colours ──────────────────────────────── */
+
+static float color_dim_bg[16]     = COLOR_HEX_TO_FLOAT(0x000000, 0.62f);
+static float color_panel[16]      = COLOR_HEX_TO_FLOAT(0x1d2021, 0.95f);
+static float color_title_bg[16]   = COLOR_HEX_TO_FLOAT(0x3c3836, 1.0f);
+static float color_selected[16]   = COLOR_HEX_TO_FLOAT(0xd65d0e, 0.35f);
+static float color_divider[16]    = COLOR_HEX_TO_FLOAT(0x504945, 0.50f);
+
+/* ABGR format for gfx_display_draw_text (0xAABBGGRR) */
+#define TEXT_COLOR_CREAM    0xFFC7F1FBu   /* #FBF1C7 */
+#define TEXT_COLOR_ORANGE   0xFF0E5DD6u   /* #D65D0E */
+#define TEXT_COLOR_DIM      0xFF8499A8u   /* #A89984 */
+
+/* ── State ─────────────────────────────────────────────────── */
+
+static struct
+{
+   bool        active;
+   bool        was_paused;       /* pause state before IGM opened  */
+   bool        open_ra_menu;     /* deferred: open RA menu on close */
+   bool        bypass_hook;      /* let next MENU_TOGGLE pass through */
+   int         selected;
+   font_data_t *font;
+   font_data_t *font_small;
+   uint16_t    prev_buttons;     /* previous frame joypad bits      */
+} igm;
+
+/* ── Helpers ───────────────────────────────────────────────── */
+
+/* Read all joypad buttons for port 0 as a bitmask */
+static uint16_t igm_read_buttons(void)
+{
+   unsigned i;
+   uint16_t bits = 0;
+   for (i = 0; i <= RETRO_DEVICE_ID_JOYPAD_R3; i++)
+   {
+      if (input_driver_state_wrapper(0, RETRO_DEVICE_JOYPAD, 0, i))
+         bits |= (1 << i);
+   }
+   return bits;
+}
+
+/* Return buttons that just went from released → pressed */
+#define IGM_PRESSED(cur, prev, btn) \
+   (((cur) & (1 << (btn))) && !((prev) & (1 << (btn))))
+
+/* ── Bypass ────────────────────────────────────────────────── */
+
+/* Called from the CMD_EVENT_MENU_TOGGLE hook.
+ * Returns true (and clears the flag) when the IGM wants the
+ * real RA menu to open instead of itself. */
+bool spruce_igm_check_and_clear_bypass(void)
+{
+   if (igm.bypass_hook)
+   {
+      igm.bypass_hook = false;
+      return true;
+   }
+   return false;
+}
+
+/* ── Toggle ────────────────────────────────────────────────── */
+
+void spruce_igm_toggle(void)
+{
+   if (igm.active)
+   {
+      /* Close IGM */
+      igm.active = false;
+
+      /* Restore previous pause state */
+      runloop_state_t *runloop_st = runloop_state_get_ptr();
+      bool is_paused = (runloop_st->flags & RUNLOOP_FLAG_PAUSED) != 0;
+      if (is_paused && !igm.was_paused)
+         command_event(CMD_EVENT_PAUSE_TOGGLE, NULL);
+
+      /* If user chose "RetroArch Menu", open it now
+       * by setting the bypass flag so our hook lets it through */
+      if (igm.open_ra_menu)
+      {
+         igm.open_ra_menu = false;
+         igm.bypass_hook  = true;
+         command_event(CMD_EVENT_MENU_TOGGLE, NULL);
+      }
+   }
+   else
+   {
+      /* Open IGM */
+      runloop_state_t *runloop_st = runloop_state_get_ptr();
+      igm.was_paused = (runloop_st->flags & RUNLOOP_FLAG_PAUSED) != 0;
+      igm.active     = true;
+      igm.selected   = 0;
+      igm.open_ra_menu = false;
+
+      /* Flush button state so we don't act on the toggle press itself */
+      igm.prev_buttons = 0xFFFF;
+
+      /* Pause the core if it isn't already */
+      if (!igm.was_paused)
+         command_event(CMD_EVENT_PAUSE_TOGGLE, NULL);
+   }
+}
+
+bool spruce_igm_is_active(void)
+{
+   return igm.active;
+}
+
+/* ── Input handling (called every frame while active) ──────── */
+
+static void igm_handle_input(void)
+{
+   uint16_t cur  = igm_read_buttons();
+   uint16_t prev = igm.prev_buttons;
+   igm.prev_buttons = cur;
+
+   settings_t *settings = config_get_ptr();
+
+   /* D-pad up */
+   if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_UP))
+   {
+      igm.selected--;
+      if (igm.selected < 0)
+         igm.selected = IGM_ITEM_COUNT - 1;
+   }
+
+   /* D-pad down */
+   if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_DOWN))
+   {
+      igm.selected++;
+      if (igm.selected >= IGM_ITEM_COUNT)
+         igm.selected = 0;
+   }
+
+   /* D-pad left / right — change state slot (on save/load rows) */
+   if (igm.selected == IGM_SAVE_STATE || igm.selected == IGM_LOAD_STATE)
+   {
+      if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_LEFT))
+         command_event(CMD_EVENT_SAVE_STATE_DECREMENT, NULL);
+      if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_RIGHT))
+         command_event(CMD_EVENT_SAVE_STATE_INCREMENT, NULL);
+   }
+
+   /* B button — close (resume) */
+   if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_B))
+   {
+      spruce_igm_toggle(); /* close */
+      return;
+   }
+
+   /* A button — activate selected item */
+   if (IGM_PRESSED(cur, prev, RETRO_DEVICE_ID_JOYPAD_A))
+   {
+      switch (igm.selected)
+      {
+         case IGM_RESUME:
+            spruce_igm_toggle(); /* close */
+            return;
+         case IGM_SAVE_STATE:
+            command_event(CMD_EVENT_SAVE_STATE, NULL);
+            break;
+         case IGM_LOAD_STATE:
+            command_event(CMD_EVENT_LOAD_STATE, NULL);
+            spruce_igm_toggle(); /* close after load */
+            return;
+         case IGM_RESET:
+            spruce_igm_toggle(); /* close first */
+            command_event(CMD_EVENT_RESET, NULL);
+            return;
+         case IGM_EXIT:
+            command_event(CMD_EVENT_QUIT, NULL);
+            return;
+         case IGM_RETROARCH:
+            igm.open_ra_menu = true;
+            spruce_igm_toggle(); /* close, then opens RA menu */
+            return;
+      }
+   }
+}
+
+/* ── Rendering ─────────────────────────────────────────────── */
+
+void spruce_igm_frame(
+      gfx_display_t *p_disp,
+      void *userdata,
+      unsigned video_width,
+      unsigned video_height)
+{
+   int i;
+   char slot_buf[64];
+   settings_t *settings;
+
+   if (!igm.active)
+      return;
+
+   /* Lazy-load fonts on first render */
+   if (!igm.font)
+   {
+      igm.font       = gfx_display_font_file(p_disp, NULL,
+                           video_height / 20.0f, false);
+      igm.font_small = gfx_display_font_file(p_disp, NULL,
+                           video_height / 28.0f, false);
+   }
+   if (!igm.font)
+      return;
+
+   /* Handle input */
+   igm_handle_input();
+   /* igm_handle_input may close the menu */
+   if (!igm.active)
+      return;
+
+   settings = config_get_ptr();
+
+   /* ── Layout constants (proportional to screen) ─────── */
+   int panel_w = video_width  * 38 / 100;   /* ~38% of screen width  */
+   int item_h  = video_height * 8  / 100;   /* ~8% per row           */
+   int panel_h = item_h * IGM_ITEM_COUNT + item_h;  /* items + title */
+   int panel_x = (video_width  - panel_w) / 2;
+   int panel_y = (video_height - panel_h) / 2;
+   int title_h = item_h;
+
+   /* ── Full-screen dim ───────────────────────────────── */
+   gfx_display_draw_quad(p_disp, userdata,
+         video_width, video_height,
+         0, 0, video_width, video_height,
+         video_width, video_height,
+         color_dim_bg, NULL);
+
+   /* ── Panel background ──────────────────────────────── */
+   gfx_display_draw_quad(p_disp, userdata,
+         video_width, video_height,
+         panel_x, panel_y, panel_w, panel_h,
+         video_width, video_height,
+         color_panel, NULL);
+
+   /* ── Title bar ─────────────────────────────────────── */
+   gfx_display_draw_quad(p_disp, userdata,
+         video_width, video_height,
+         panel_x, panel_y, panel_w, title_h,
+         video_width, video_height,
+         color_title_bg, NULL);
+
+   if (igm.font_small)
+      gfx_display_draw_text(igm.font_small, "QUICK MENU",
+            (float)(video_width / 2),
+            (float)(panel_y + title_h * 0.68f),
+            video_width, video_height,
+            TEXT_COLOR_ORANGE,
+            TEXT_ALIGN_CENTER,
+            1.0f, false, 0.0f, false);
+
+   /* ── Menu items ────────────────────────────────────── */
+   for (i = 0; i < IGM_ITEM_COUNT; i++)
+   {
+      int iy        = panel_y + title_h + i * item_h;
+      bool selected = (i == igm.selected);
+
+      /* Divider line */
+      if (i > 0)
+         gfx_display_draw_quad(p_disp, userdata,
+               video_width, video_height,
+               panel_x + panel_w / 20, iy,
+               panel_w - panel_w / 10, 1,
+               video_width, video_height,
+               color_divider, NULL);
+
+      /* Selection highlight */
+      if (selected)
+         gfx_display_draw_quad(p_disp, userdata,
+               video_width, video_height,
+               panel_x, iy, panel_w, item_h,
+               video_width, video_height,
+               color_selected, NULL);
+
+      /* Label text */
+      {
+         uint32_t text_col;
+         const char *label = igm_labels[i];
+
+         if (i == IGM_RETROARCH)
+            text_col = TEXT_COLOR_DIM;
+         else if (selected)
+            text_col = TEXT_COLOR_ORANGE;
+         else
+            text_col = TEXT_COLOR_CREAM;
+
+         gfx_display_draw_text(igm.font, label,
+               (float)(video_width / 2),
+               (float)(iy + item_h * 0.68f),
+               video_width, video_height,
+               text_col,
+               TEXT_ALIGN_CENTER,
+               1.0f, false, 0.0f, false);
+      }
+
+      /* Slot indicator for Save/Load State rows */
+      if ((i == IGM_SAVE_STATE || i == IGM_LOAD_STATE) && igm.font_small)
+      {
+         int slot = settings->ints.state_slot;
+         snprintf(slot_buf, sizeof(slot_buf), "Slot %d", slot);
+
+         /* Arrows */
+         gfx_display_draw_text(igm.font, "\xe2\x97\x80",
+               (float)(panel_x + panel_w / 10),
+               (float)(iy + item_h * 0.68f),
+               video_width, video_height,
+               selected ? TEXT_COLOR_ORANGE : TEXT_COLOR_DIM,
+               TEXT_ALIGN_CENTER,
+               1.0f, false, 0.0f, false);
+
+         gfx_display_draw_text(igm.font, "\xe2\x96\xb6",
+               (float)(panel_x + panel_w - panel_w / 10),
+               (float)(iy + item_h * 0.68f),
+               video_width, video_height,
+               selected ? TEXT_COLOR_ORANGE : TEXT_COLOR_DIM,
+               TEXT_ALIGN_CENTER,
+               1.0f, false, 0.0f, false);
+
+         /* Slot number below label */
+         gfx_display_draw_text(igm.font_small, slot_buf,
+               (float)(video_width / 2),
+               (float)(iy + item_h * 0.92f),
+               video_width, video_height,
+               TEXT_COLOR_DIM,
+               TEXT_ALIGN_CENTER,
+               1.0f, false, 0.0f, false);
+      }
+   }
+
+   /* ── Bottom hint ───────────────────────────────────── */
+   if (igm.font_small)
+   {
+      gfx_display_draw_text(igm.font_small,
+            "\xe2\x86\x91\xe2\x86\x93 Navigate   A Select   B Close",
+            (float)(video_width / 2),
+            (float)(panel_y + panel_h + video_height / 30),
+            video_width, video_height,
+            TEXT_COLOR_DIM,
+            TEXT_ALIGN_CENTER,
+            1.0f, false, 0.0f, false);
+   }
+}
diff --git a/spruce_igm.h b/spruce_igm.h
new file mode 100644
index 0000000..e6235a4
--- /dev/null
+++ b/spruce_igm.h
@@ -0,0 +1,17 @@
+#ifndef SPRUCE_IGM_H
+#define SPRUCE_IGM_H
+
+#include <boolean.h>
+
+#include "gfx/gfx_display.h"
+
+void spruce_igm_toggle(void);
+bool spruce_igm_is_active(void);
+bool spruce_igm_check_and_clear_bypass(void);
+void spruce_igm_frame(
+      gfx_display_t *p_disp,
+      void *userdata,
+      unsigned video_width,
+      unsigned video_height);
+
+#endif /* SPRUCE_IGM_H */
