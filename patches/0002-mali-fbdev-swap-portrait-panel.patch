+   /* Some devices (e.g. Miyoo A30) have portrait panels (480x640) that are
+    * rotated by the display engine for landscape use.  The fbdev ioctl still
+    * reports the native portrait dimensions, but the EGL surface should be
+    * created in landscape orientation so the entire rendering pipeline
+    * (core + OSD) comes out correctly rotated. */
+   if (vinfo.xres < vinfo.yres)
+   {
+      mali->width                = vinfo.yres;
+      mali->height               = vinfo.xres;
+      mali->native_window.width  = vinfo.yres;
+      mali->native_window.height = vinfo.xres;
+   }
+   else
+   {
+      mali->width                = vinfo.xres;
+      mali->height               = vinfo.yres;
+      mali->native_window.width  = vinfo.xres;
+      mali->native_window.height = vinfo.yres;
+   }
 
