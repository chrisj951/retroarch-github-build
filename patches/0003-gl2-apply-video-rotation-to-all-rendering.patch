diff --git a/gfx/drivers/gl2.c b/gfx/drivers/gl2.c
index d39eb15..f7adeff 100644
--- a/gfx/drivers/gl2.c
+++ b/gfx/drivers/gl2.c
@@ -1308,7 +1308,16 @@ static void gl2_set_viewport(gl2_t *gl,
       gl->vp.height = vp_height;
    }
 
-   glViewport(gl->vp.x, gl->vp.y, gl->vp.width, gl->vp.height);
+   /* When video_rotation is 90/270, the logical viewport (calculated for
+    * landscape dimensions) must be mapped to the physical portrait
+    * framebuffer by swapping x<->y and width<->height. */
+   {
+      unsigned vid_rot = config_get_ptr()->uints.video_rotation;
+      if (vid_rot % 2 != 0)
+         glViewport(gl->vp.y, gl->vp.x, gl->vp.height, gl->vp.width);
+      else
+         glViewport(gl->vp.x, gl->vp.y, gl->vp.width, gl->vp.height);
+   }
    gl2_set_projection(gl, &default_ortho, allow_rotate);
 
    /* Set last backbuffer viewport. */
